# ==========================================
# Core Languages & OS
# ==========================================
# Python byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
*.so

# macOS specific files
.DS_Store
Thumbs.db

# ==========================================
# Project Infrastructure & Security
# ==========================================
# Terraform state, locks, and cache (Global catch-all)
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
*.tfvars.json

# Local Kubernetes / Kind credentials
*.kubeconfig

# Explicitly ignored sensitive project configs


# Logs and crashes
*.log
crash.log

# ==========================================
# Local Environments & Tools
# ==========================================
# Python virtual environments
.env
.envrc
.venv
env/
venv/
ENV/

# IDE and Editor configs (VS Code, Cursor, JetBrains)
.vscode/
.idea/
.cursorignore
.cursorindexingignore

# Testing, formatting, and linting caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build and distribution directories
build/
dist/
*.egg-info/